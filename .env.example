# Maro — AI configuration
# Copy this file to .env.local and fill in your key. .env.local is gitignored.

# Anthropic API key (https://console.anthropic.com/). Required for real AI.
# If omitted, Maro falls back to the local mock AI so the app still runs.
ANTHROPIC_API_KEY=

# Model + reasoning effort (defaults shown). Opus 4.8 uses adaptive thinking.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_EFFORT=high
