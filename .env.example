# Maro Beta — environment configuration
# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# ---- Anthropic (Claude Opus 4.8) — Maro Website ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_EFFORT=high

# ---- OpenAI (image tools: Maro Logo, Maro Reklama) ----
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# ---- ElevenLabs (audio tool: maro Zo) ----
ELEVENLABS_API_KEY=
# Optional: override default voice ids used for Femëror / Mashkullor
ELEVEN_VOICE_FEMALE=
ELEVEN_VOICE_MALE=

# ---- Supabase ----
# From Supabase dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SERVER ONLY — never exposed to the browser). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=
